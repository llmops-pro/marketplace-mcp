# Copy to .env and fill in. .env is gitignored.
# Env vars passed by the parent process (Claude Code, etc.) take precedence.

# Signer — provide AT MOST ONE. Without a signer the server runs read-only:
# list_my_stalls / list_my_products refuse (can't determine `me`), but the
# config still loads cleanly so you can poke at the bundle.
#
# Recommended for buyer setups: NIP-46 bunker (keeps the nsec on your phone).

# NOSTR_NIP46_URI=bunker://<pubkey>?relay=wss://relay.example.com&secret=...

# Legacy / dev only.
# NOSTR_PRIVATE_KEY=nsec1...

# Relays. Required. Comma-separated wss:// URLs. Use major public relays.
# (Note: shopstr.store's UI does NOT read from open relays — it reads from its
# own Postgres cache. See SHOPSTR_CACHE_* below.)
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band,wss://relay.primal.net

# Optional ----------------------------------------------------------------

# Force read-only — disables all publish tools. Useful for dry-run inspection.
# NOSTR_READ_ONLY=false

# Two-step confirmation for publishes — returns a token, marketplace_confirm_publish
# executes. Trades autonomy for safety.
# NOSTR_REQUIRE_CONFIRM=false

# Rate limit — rolling 60s window, applied to publishes.
# NOSTR_MAX_EVENTS_PER_MINUTE=10

# Shopstr cache mirror ---------------------------------------------------
#
# shopstr.store's UI reads from its own Postgres DB, not from relays. After a
# successful relay publish of kind:30019 (shop profile) or kind:30402 (NIP-99
# product), the server can POST the signed event to Shopstr's cache endpoint
# so it appears on the storefront. Default URL is the public Shopstr instance;
# point at a self-hosted Shopstr deployment to mirror there instead.
#
# This only affects the `shopstr_create_or_update_*` tools — the NIP-15 tools
# (kind:30017/30018) ignore this setting.
SHOPSTR_CACHE_ENABLED=true
# SHOPSTR_CACHE_URL=https://shopstr.store/api/db/cache-event

# Logging.
# NOSTR_LOG_PATH=./marketplace-mcp.log
# NOSTR_AUDIT_PATH=./marketplace-mcp-audit.log
